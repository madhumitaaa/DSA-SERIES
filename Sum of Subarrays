class Solution {
  public:
    int subarraySum(vector<int>& arr) {
        // code here
        int n=arr.size();
        long long sum=0;
      
       for(int i=0;i<n;i++)
       {
           sum+=arr[i]*(i+1)*(n-i);
       }
        return (int)sum;
    }
};
