https://leetcode.com/problems/find-pivot-index/submissions/1951142850/

class Solution {
public:
    int pivotIndex(vector<int>& nums) {
        int n=nums.size();
        int total=accumulate(nums.begin(),nums.end(),0);
        int leftsum=0;
        for(int i=0;i<n;i++)
        {
            int sum=total-leftsum-nums[i];
            if(sum==leftsum)return i;
            leftsum+=nums[i];
        }
        return -1;
    }
};
