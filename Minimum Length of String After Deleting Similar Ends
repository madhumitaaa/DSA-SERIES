https://leetcode.com/problems/minimum-length-of-string-after-deleting-similar-ends/submissions/1955670992/

class Solution {
public:
    int minimumLength(string s) {
        int n=s.size();
        int l=0,r=n-1;
      
    while(l<r && s[l]==s[r]){
        char ch=s[l];
       
        while(l<=r && s[l]==ch){
                    l++;
        }
          while(l<=r && s[r]==ch){
                    r--;
        }
        
    }
   
        
       return r-l+1;
       
    }
};
